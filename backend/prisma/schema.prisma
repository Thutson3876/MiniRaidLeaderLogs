generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model Battle {
  id              Int            @id @default(autoincrement())
  battleWon       Boolean        @map("battle_won")
  battleDuration  Decimal        @map("battle_duration") @db.Decimal(10, 2)
  difficulty      Int            @default(0)
  bossId          Int            @map("boss_id") @default(0)
  recordedAt      DateTime       @default(now()) @map("recorded_at") @db.Timestamptz

  damageEntries   DamageEntry[]
  staggerEntries  StaggerEntry[]
  healingEntries  HealingEntry[]
  modifiers       BattleModifier[]
  boss            Boss           @relation(fields: [bossId], references: [id])

  @@map("battles")
}

model Boss {
  id          Int      @id
  name        String   @db.VarChar(100)
  description String   @db.Text
  color       String   @db.VarChar(50)

  battles     Battle[]

  @@map("bosses")
}

model Modifier {
  id          Int      @id
  name        String   @db.VarChar(100)
  description String   @db.Text
  color       String   @db.VarChar(50)
  sprite      String   @db.VarChar(255)

  battles     BattleModifier[]

  @@map("modifiers")
}

model BattleModifier {
  battleId   Int      @map("battle_id")
  modifierId Int      @map("modifier_id")

  battle     Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  modifier   Modifier @relation(fields: [modifierId], references: [id])

  @@id([battleId, modifierId])

  @@map("battle_modifiers")
}

model DamageEntry {
  id          Int      @id @default(autoincrement())
  battleId    Int      @map("battle_id")
  playerClass String   @map("player_class") @db.VarChar(100)
  amount      Decimal  @db.Decimal(12, 2)
  battle      Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@map("damage_entries")
}

model StaggerEntry {
  id          Int      @id @default(autoincrement())
  battleId    Int      @map("battle_id")
  playerClass String   @map("player_class") @db.VarChar(100)
  amount      Decimal  @db.Decimal(12, 2)
  battle      Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@map("stagger_entries")
}

model HealingEntry {
  id          Int      @id @default(autoincrement())
  battleId    Int      @map("battle_id")
  playerClass String   @map("player_class") @db.VarChar(100)
  amount      Decimal  @db.Decimal(12, 2)
  battle      Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@map("healing_entries")
}